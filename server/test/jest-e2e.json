{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "./",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(ts)$": "ts-jest"
  },
  "modulePaths": ["../src"],
  "moduleNameMapper": {
    "^@blockchain/(.*)$": "<rootDir>/../blockchain/dist/$1"
  }
}

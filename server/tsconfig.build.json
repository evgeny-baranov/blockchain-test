// server/tsconfig.build.json
{
  "extends": "./tsconfig.json",
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*.spec.ts",
    "../blockchain/dist"
  ],
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@blockchain/*": [
        "../../blockchain/dist/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}

{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "composite": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "types": [
      "node",
      "hardhat",
      "@nomicfoundation/hardhat-ethers",
      "@openzeppelin/hardhat-upgrades"
    ],
    "paths": {
      "@blockchain/*": [
        "./typechain-types/*"
      ]
    }
  },
  "include": [
    "typechain-types/**/*"
  ]
}
